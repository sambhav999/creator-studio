PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173,https://your-creator-studio-domain.example

# Optional production integrations
OPENAI_API_KEY=
ZERO_G_API_KEY=
ZERO_G_BASE_URL=https://router-api.0g.ai/v1
LLM_PROVIDER=0g
LLM_MODEL=MiniMax-M3
ZERO_G_ORCHESTRATOR_MODEL=glm-5.2
ZERO_G_CODING_MODEL=deepseek-v4-flash
ZERO_G_BACKGROUND_MODEL=deepseek-v4-flash
ZERO_G_IMAGE_MODEL=z-image-turbo
ZERO_G_VISION_MODEL=qwen/qwen3-vl-30b-a3b-instruct
ZERO_G_SPEECH_MODEL=openai/whisper-large-v3

# 0G Storage SDK. Keep the private key server-side only.
# Current sample endpoints are testnet. Use mainnet endpoints deliberately for production.
ZERO_G_STORAGE_ENABLED=true
ZERO_G_STORAGE_INDEXER_RPC=https://indexer-storage-testnet-turbo.0g.ai
ZERO_G_STORAGE_EVM_RPC=https://evmrpc-testnet.0g.ai
ZERO_G_STORAGE_PRIVATE_KEY=
ZERO_G_STORAGE_EXPECTED_REPLICA=1
ZERO_G_STORAGE_COLLECTION=zero_g_storage_objects

MONGODB_URI=mongodb://localhost:27017/prompt_creator_studio
MONGODB_COLLECTION=prompt_creator_studio
REDIS_URL=redis://localhost:6379

IPFS_API_URL=
IPFS_API_KEY=
IPFS_API_SECRET=

WEB3_PROVIDER_URL=
CONTRACT_ADDRESS=
ZERO_G_MAINNET_RPC_URL=https://evmrpc.0g.ai
ZERO_G_MAINNET_CHAIN_ID=16661

# 0G on-chain activity registry. Keep the private key server-side only.
# CONTRACT_DEPLOYER_ADDRESS is supported as a legacy fallback if it contains a
# private key, but ZERO_G_ACTIVITY_PRIVATE_KEY is the preferred name.
ZERO_G_ACTIVITY_ENABLED=true
ZERO_G_ACTIVITY_RPC_URL=https://evmrpc.0g.ai
ZERO_G_ACTIVITY_CHAIN_ID=16661
ZERO_G_ACTIVITY_PRIVATE_KEY=
ZERO_G_ACTIVITY_CONTRACT_ADDRESS=
ZERO_G_ACTIVITY_CONFIRMATIONS=1
ZERO_G_ACTIVITY_COLLECTION=zero_g_onchain_activities

ZERO_G_PAYMENT_RPC_URL=https://evmrpc.0g.ai
ZERO_G_PAYMENT_CHAIN_ID=16661
ZERO_G_PAYMENT_CONTRACT_ADDRESS=
ZERO_G_TREASURY_WALLET=0x49b5401d01BBbd5B54352b293A3B58366DeE8F27
ZERO_G_PAYMENT_CONFIRMATIONS=1

# Auth. Use a cryptographically random value, at least 32 bytes.
JWT_SECRET=
JWT_EXPIRATION_DAYS=7
PRIVY_APP_ID=
PRIVY_VERIFICATION_KEY=

PUBLIC_APP_URL=http://localhost:5173/studio
REFERRAL_BASE_URL=http://localhost:3001

# Referral security. Use random production-only values.
REFERRAL_ADMIN_KEY=
REFERRAL_IP_SALT=

# First generated game per wallet is free. Additional generations require this
# amount of TON by default. For Telegram Mini App payments, paymentTxHash carries
# the unique TON payment reference/comment that the backend verifies on-chain.
PAID_GAME_CURRENCY=TON
PAID_GAME_PRICE_TON=1
TON_RPC_URL=https://toncenter.com/api/v2/jsonRPC
TON_API_KEY=
TON_TREASURY_WALLET=
TON_PAYMENT_CONFIRMATIONS=1
TON_PAYMENT_VERIFY_ATTEMPTS=8
TON_PAYMENT_VERIFY_DELAY_MS=3000

# Legacy 0G payment fallback. Set PAID_GAME_CURRENCY=0G to use this path.
PAID_GAME_PRICE_0G=2

# DigitalOcean Spaces - generated thumbnails are stored here, URLs in MongoDB.
SPACES_ENDPOINT=https://sfo3.digitaloceanspaces.com
SPACES_REGION=sfo3
SPACES_BUCKET=creator-studio
SPACES_KEY=
SPACES_SECRET=
# Optional: CDN base override, e.g. https://creator-studio.sfo3.cdn.digitaloceanspaces.com
SPACES_PUBLIC_BASE=
